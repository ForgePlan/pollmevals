# Core
NODE_ENV=development
POLLMEVALS_API_PORT=8787
POLLMEVALS_ARTIFACT_ROOT=./artifacts
POLLMEVALS_PUBLIC_BASE_URL=http://localhost:3000
POLLMEVALS_API_BASE_URL=http://localhost:8787

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pollmevals
POSTGRES_USER=pollmevals
POSTGRES_PASSWORD=pollmevals_dev_password
DATABASE_URL=postgresql://pollmevals:pollmevals_dev_password@localhost:5432/pollmevals

# Redis / NATS
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# LiteLLM
LITELLM_MASTER_KEY=sk-local-pollmevals-dev
LITELLM_DATABASE_URL=postgresql://litellm:litellm_dev_password@localhost:5433/litellm
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_JUDGE=
CEREBRAS_API_KEY=
RUNPOD_VLLM_API_BASE=
RUNPOD_VLLM_KEY=

# Object storage production values
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=pollmevals-artifacts
