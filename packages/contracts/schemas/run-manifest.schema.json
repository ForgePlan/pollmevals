{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pollmevals.local/schemas/run-manifest.schema.json",
  "title": "POLLMEVALS Run Manifest",
  "description": "Canonical manifest for one POLLMEVALS run (smoke / weekly / etc.). Aligned with SPEC-001 (forgeplan artifact). Bumped from v1 thin schema to v1.0.0 rich schema 2026-05-23 per architect-reviewer finding #3 (schema drift between SPEC-001 and on-disk).",
  "type": "object",
  "required": [
    "schema_version",
    "run_hash",
    "run_type",
    "methodology_version",
    "created_at",
    "stack_pins",
    "model_pins",
    "task_pins",
    "seed_set",
    "evals",
    "aggregates",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": "pollmevals.run_manifest.v1.0.0",
      "description": "Bumped from v1 (thin) to v1.0.0 (rich) — see SPEC-001 mapping table."
    },
    "run_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Content-addressed: sha256(methodology_version + sorted stack_pins + sorted model_pins + sorted task_pins + seed_set)"
    },
    "run_type": {
      "enum": ["smoke", "weekly", "flagship_triggered", "calibration", "ablation"]
    },
    "methodology_version": {
      "type": "string",
      "const": "v0.1.0",
      "description": "References docs/02-methodology/ frozen version. Bumping is an ADR-level decision."
    },
    "created_at": { "type": "string", "format": "date-time" },
    "published_at": { "type": ["string", "null"], "format": "date-time" },
    "region": { "type": "string", "enum": ["eu-central"] },
    "stack_pins": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/StackPin" }
    },
    "model_pins": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ModelPin" }
    },
    "task_pins": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/TaskPin" }
    },
    "seed_set": {
      "type": "array",
      "items": { "type": "integer" },
      "minItems": 1
    },
    "evals": {
      "type": "array",
      "items": { "$ref": "#/$defs/EvalRow" }
    },
    "aggregates": { "$ref": "#/$defs/RunAggregates" },
    "status": {
      "enum": ["created", "executing", "evaluating", "aggregating", "published", "degraded"],
      "description": "State machine. `published` and `degraded` are terminal; write-once after these (ADR-0002 legacy)."
    },
    "inspect_eval_log_sha256": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA256 of underlying Inspect AI .eval binary; cross-references opaque log to manifest (EVID-004)."
    },
    "inspect_ai_version": {
      "type": "string",
      "description": "Pinned in pyproject.toml; required for reproducibility."
    },
    "orchestrator_version": {
      "type": "string",
      "description": "pollmevals git tag at run time."
    }
  },
  "$defs": {
    "StackPin": {
      "type": "object",
      "required": ["stack_id", "stack_version", "stack_yaml_sha256"],
      "properties": {
        "stack_id": { "type": "string" },
        "stack_version": { "type": "string" },
        "stack_yaml_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "ModelPin": {
      "type": "object",
      "required": ["model_id", "provider_id", "provider_route_id", "pricing_snapshot"],
      "properties": {
        "model_id": { "type": "string" },
        "provider_id": {
          "type": "string",
          "description": "Inspect AI prefix: anthropic/openai/google/openrouter/hosted_vllm/ollama"
        },
        "provider_route_id": {
          "type": "string",
          "description": "Full route, e.g. openrouter/anthropic/claude-sonnet-4-6"
        },
        "pricing_snapshot": {
          "type": "object",
          "required": ["input_per_mtoken_usd", "output_per_mtoken_usd", "snapshot_at"],
          "properties": {
            "input_per_mtoken_usd": { "type": "number", "minimum": 0 },
            "output_per_mtoken_usd": { "type": "number", "minimum": 0 },
            "snapshot_at": { "type": "string", "format": "date-time" }
          },
          "description": "Frozen at run start. Closes industry gap (HELM/SWE-bench) per EVID-001/EVID-005."
        }
      }
    },
    "TaskPin": {
      "type": "object",
      "required": ["task_id", "task_version", "task_pack_sha256"],
      "properties": {
        "task_id": { "type": "string" },
        "task_version": { "type": "string" },
        "task_pack_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "Content-addressed hash of (prompt + evaluator + gold) — POLLMEVALS divergence from lm-eval-harness integer versioning (EVID-003)."
        }
      }
    },
    "EvalRow": {
      "type": "object",
      "required": ["eval_id", "model_id", "stack_id", "task_id", "seed", "status", "artifact_refs", "stats"],
      "properties": {
        "eval_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{16}$",
          "description": "sha256(run_hash + model_id + stack_id + task_id + seed)[:16]"
        },
        "model_id": { "type": "string" },
        "stack_id": { "type": "string" },
        "task_id": { "type": "string" },
        "seed": { "type": "integer" },
        "status": {
          "enum": ["pending", "running", "scored", "failed", "skipped"],
          "description": "Failed evals MUST be stored, NOT dropped from denominator (PRD-001 FR-009)."
        },
        "error_class": {
          "type": ["string", "null"],
          "enum": [null, "network", "rate_limit", "5xx_server", "4xx_client", "timeout", "contract_violation", "sandbox_failure"]
        },
        "error_detail": { "type": ["string", "null"] },
        "artifact_refs": {
          "type": "object",
          "required": ["raw_output", "normalized_output", "evaluator_json"],
          "properties": {
            "raw_output": { "$ref": "#/$defs/ArtifactRef" },
            "normalized_output": { "$ref": "#/$defs/ArtifactRef" },
            "evaluator_json": { "$ref": "#/$defs/ArtifactRef" },
            "stdout": { "$ref": "#/$defs/ArtifactRef" },
            "stderr": { "$ref": "#/$defs/ArtifactRef" },
            "trace_json": { "$ref": "#/$defs/ArtifactRef" }
          }
        },
        "final_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 10,
          "description": "null in smoke (no judges); PRD-002+ = median of judge panel."
        },
        "automatic_metrics": {
          "type": "object",
          "description": "Task-specific. be_01: {test_pass_rate, lint_errors, complexity, coverage}. doc_01: {structural_completeness, link_validity, code_block_count}."
        },
        "stats": {
          "type": "object",
          "required": ["input_tokens", "output_tokens", "wall_clock_ms", "cost_usd"],
          "properties": {
            "input_tokens": { "type": "integer", "minimum": 0 },
            "output_tokens": { "type": "integer", "minimum": 0 },
            "wall_clock_ms": { "type": "integer", "minimum": 0 },
            "cost_usd": {
              "type": "number",
              "minimum": 0,
              "description": "Computed: input_tokens * pricing_snapshot.input_per_mtoken / 1e6 + output equivalent. POLLMEVALS layer (EVID-004 gap)."
            }
          }
        },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "ArtifactRef": {
      "type": "object",
      "required": ["sha256", "size_bytes", "uri", "mime_type"],
      "properties": {
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "uri": {
          "type": "string",
          "description": "v0.1 local: file://artifacts/runs/{run_hash}/evals/{eval_id}/{type}-{sha256}.{ext}. v0.2+ R2: s3://pollmevals-runs/..."
        },
        "mime_type": { "type": "string" }
      }
    },
    "RunAggregates": {
      "type": "object",
      "description": "Computed at status=aggregating step. Closes FR-006 gap noted by architect-reviewer #2.",
      "required": ["counts_by_status", "total_cost_usd", "total_wall_clock_ms"],
      "properties": {
        "counts_by_status": {
          "type": "object",
          "required": ["scored", "failed", "skipped"],
          "properties": {
            "pending": { "type": "integer", "minimum": 0 },
            "running": { "type": "integer", "minimum": 0 },
            "scored": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 },
            "skipped": { "type": "integer", "minimum": 0 }
          }
        },
        "counts_by_error_class": {
          "type": "object",
          "description": "Distribution of error_class values among failed evals (mirrors EvalRow.error_class enum)."
        },
        "total_cost_usd": { "type": "number", "minimum": 0 },
        "total_wall_clock_ms": { "type": "integer", "minimum": 0 },
        "per_task_metrics": {
          "type": "object",
          "description": "Map task_id → {automatic_metric_key → {mean, median, p95, sample_count}}. Smoke has no final_score aggregates (no judges); judges layer in PRD-002 will add final_score median + Krippendorff α."
        },
        "budget_breach": {
          "type": "boolean",
          "description": "True if total_cost_usd > NFR-001 cap ($50 for smoke)."
        },
        "available_models_count": {
          "type": "integer",
          "description": "Number of distinct model_ids with at least one scored eval. Drives status=degraded transition (< 3 → degraded)."
        }
      }
    }
  }
}
